{
  "$schema": "https://ui.shadcn.com/schema/registry.json",
  "name": "chakra-wind",
  "description": "Chakra UI components powered by Tailwind CSS, compatible with shadcn/ui",
  "homepage": "https://github.com/laststance/chakrawind",
  "items": [
    {
      "name": "button",
      "type": "registry:ui",
      "title": "Button",
      "description": "A Chakra Wind button component with multiple variants and sizes.",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "ui/button.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "badge",
      "type": "registry:ui",
      "title": "Badge",
      "description": "A Chakra Wind badge component with multiple variants.",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "ui/badge.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "separator",
      "type": "registry:ui",
      "title": "Separator",
      "description": "A Chakra Wind separator/divider component.",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "ui/separator.tsx",
          "type": "registry:ui"
        }
      ]
    },
    {
      "name": "utils",
      "type": "registry:lib",
      "title": "Utilities",
      "description": "Core utilities for Chakra Wind (cn, style-props).",
      "dependencies": ["clsx", "tailwind-merge"],
      "files": [
        {
          "path": "lib/utils.ts",
          "type": "registry:lib"
        }
      ]
