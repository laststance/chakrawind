{
  "name": "chakrawind-ui",
  "private": true,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/laststance/chakrawind.git"
  },
  "author": "Laststance.io <https://github.com/laststance>",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "build": "pnpm --filter=./packages/* build",
    "build:fast": "pnpm --filter=./packages/* build:fast",
    "dev": "pnpm --recursive --parallel --filter=./packages/* dev",
    "typedocs": "pnpm react typedocs",
    "typecheck": "tsc --noEmit",
    "test": "vitest --project=unit",
    "react": "pnpm --filter=@laststance/chakrawind-ui",
    "lint": "eslint packages --ext .ts,.tsx --cache",
    "format:check": "prettier --check packages --cache",
    "format:write": "prettier --write packages --cache",
    "clean:modules": "find . -name node_modules -type d -prune -exec rm -rf {} +",
    "clean:storybook": "rm -rf node_modules/.cache/storybook",
    "storybook": "storybook dev -p 6006",
    "build:storybook": "pnpm build:fast && storybook build",
    "serve:storybook": "pnpx serve storybook-static",
    "clean": "pnpm -r --parallel exec rimraf dist *.log",
    "next:enter": "changeset pre enter next",
    "next:exit": "changeset pre exit next",
    "version": "changeset version",
    "release": "changeset publish",
    "version:dev": "changeset version --snapshot dev",
    "release:dev": "changeset publish --tag dev",
    "test-storybook": "vitest --project=storybook",
    "test-storybook:coverage": "vitest --project=storybook --coverage",
    "test-visual": "chromatic --build-script-name=build:storybook",
    "gate:api": "tsx scripts/gates/check-api.ts",
    "gate:types": "tsx scripts/gates/check-types.ts",
    "gate:runtime": "tsx scripts/gates/check-runtime.ts",
    "gate:a11y": "tsx scripts/gates/check-a11y.ts",
    "gate:visual": "tsx scripts/gates/check-visual.ts",
    "gate:coexist": "tsx scripts/gates/check-coexist.ts",
    "gate:install": "tsx scripts/gates/check-install.ts",
    "gate:realworld": "tsx scripts/gates/check-realworld.ts",
    "gate:all": "tsx scripts/gates/run-all.ts"
  },
  "version": "0.1.0",
  "dependencies": {
    "@changesets/changelog-github": "0.5.2",
    "@changesets/cli": "2.29.8",
    "@changesets/get-release-plan": "4.0.14",
    "@changesets/types": "6.1.0",
    "@chromatic-com/storybook": "5.0.1",
    "@commitlint/cli": "20.4.1",
    "@commitlint/config-conventional": "20.4.1",
    "@eslint/compat": "^1.3.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.29.0",
    "@octokit/rest": "^22.0.1",
    "@rollup/plugin-alias": "6.0.0",
    "@rollup/plugin-commonjs": "^29.0.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-replace": "6.0.3",
    "@storybook/addon-a11y": "10.2.15",
    "@storybook/addon-themes": "10.2.15",
    "@storybook/addon-vitest": "10.2.15",
    "@storybook/react-vite": "10.2.15",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@trivago/prettier-plugin-sort-imports": "6.0.2",
    "@types/fs-extra": "11.0.4",
    "@types/node": "24.10.12",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/eslint-plugin": "8.56.1",
    "@typescript-eslint/parser": "8.56.1",
    "@vitest/browser-playwright": "4.0.18",
    "@vitest/coverage-v8": "4.0.18",
    "chromatic": "15.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "consola": "^3.4.2",
    "cross-env": "10.1.0",
    "dotenv": "17.2.3",
    "eslint": "9.39.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-config-react": "1.1.7",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-testing-library": "7.16.0",
    "execa": "9.6.1",
    "fast-glob": "3.3.3",
    "find-packages": "10.0.4",
    "find-up": "7.0.0",
    "fs-extra": "11.3.3",
    "globals": "^16.5.0",
    "husky": "9.1.7",
    "jsdom": "26.1.0",
    "lint-staged": "16.2.7",
    "node-fetch": "3.3.2",
    "npm-run-all": "4.1.5",
    "playwright": "1.52.0",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rimraf": "6.1.2",
    "rollup": "4.57.1",
    "rollup-plugin-esbuild": "6.2.1",
    "rollup-plugin-preserve-directives": "0.4.0",
    "storybook": "10.2.15",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tsup": "8.5.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vite": "7.3.1",
    "vitest": "4.0.18",
    "vitest-axe": "0.1.0",
    "vitest-matchmedia-mock": "2.0.3"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "immer": ">=11.0.1"
    }
  },
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=20.x"
  }
}
